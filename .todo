  Future<void> _loadDriverRoute() async {
    try {
      final acceptedRide = mapOPTController.acceptedRideData.value;
      if (acceptedRide?.isRideAcceptedDriver != true) return;

      // ✅ Driver's current location
      final LatLng driverCurrentLocation = LatLng(
        mapOPTController.currentLatitudePosition!.value,
        mapOPTController.currentLongitudePosition!.value,
      );

      // ✅ Pickup location from accepted ride data
      final pickupCoords = mapOPTController
          .rideDetailsData.value?.passengerLocation?.coordinates;

      if (pickupCoords == null || pickupCoords.length < 2) {
        debugPrint('Driver route: pickup coords not ready');
        return;
      }

      final LatLng pickupLocation = LatLng(pickupCoords[1], pickupCoords[0]);

      // Guard against 0,0 coords
      if (driverCurrentLocation.latitude == 0.0 ||
          pickupLocation.latitude == 0.0) {
        debugPrint('Driver route: coords are 0,0 — skipping');
        return;
      }

      // ✅ Get polyline from driver → pickup
      final List<LatLng> driverToPickupPoints =
          await DirectionsService.getPolyline(
        driverCurrentLocation,
        pickupLocation,
      );

      if (driverToPickupPoints.isEmpty) {
        debugPrint('Driver route: no points returned');
        return;
      }

      setState(() {
        // ✅ Add driver → pickup polyline (blue dashed)
        _polylines.add(
          Polyline(
            polylineId: const PolylineId('driver-to-pickup'),
            points: driverToPickupPoints,
            color: Colors.blue,
            width: 6,
            startCap: Cap.roundCap,
            endCap: Cap.roundCap,
            patterns: [
              PatternItem.dash(20),
              PatternItem.gap(10),
            ],
          ),
        );

        // ✅ Add driver current location marker
        markers.removeWhere(
          (m) => m.markerId.value == 'driver-current-location',
        );
        markers.add(
          Marker(
            markerId: const MarkerId('driver-current-location'),
            position: driverCurrentLocation,
            icon: customCarMarker ?? BitmapDescriptor.defaultMarker,
            infoWindow: const InfoWindow(title: 'Your Location'),
          ),
        );

        // ✅ Add pickup marker
        markers.removeWhere(
          (m) => m.markerId.value == 'driver-pickup-target',
        );
        markers.add(
          Marker(
            markerId: const MarkerId('driver-pickup-target'),
            position: pickupLocation,
            icon: customMarker ?? BitmapDescriptor.defaultMarker,
            infoWindow: const InfoWindow(title: 'Pickup Location'),
          ),
        );
      });

      // ✅ Animate camera to fit both points
      WidgetsBinding.instance.addPostFrameCallback((_) {
        final bounds = _boundsFromLatLng(driverToPickupPoints);
        _mapController?.animateCamera(
          CameraUpdate.newLatLngBounds(bounds, 80),
        );
      });
    } catch (e) {
      debugPrint('Driver route error: $e');
    }
  }



